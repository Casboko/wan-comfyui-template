COMFYUI_BASE=/workspace/ComfyUI
USE_HF_TRANSFER=1
FORCE_REDOWNLOAD=0
HF_MAX_WORKERS=4
DIRECT_MAX_WORKERS=2
INSTALL_NODES=1
NODES_PIP_INSTALL=1
NODES_FORCE_REINSTALL=0
NODES_USE_ZIP_FALLBACK=1
NODE_MANIFEST_PATH=/opt/template-config/manifests/custom_nodes.json
HF_MANIFEST_PATH=/opt/template-config/manifests/hf_models.json
ENABLED_NODE_GROUPS=core,workflow_common,workflow_svi
TEMPLATE_WORKFLOW_INCLUDE="Wan2.2_I2V_SVI_Kenpechi_Workflow_v3.5 12Sec (3).json,SVI pro.json"
ENABLED_MODEL_GROUPS=common,wan22_i2v_base,wan22_text_fp8,wan22_visual,wan22_vae,svi,lightx2v_compat
DIRECT_USE_ARIA2=1
CIVITAI_FORCE_REDOWNLOAD=0
CIVITAI_ONLY_SAFETENSORS=1
CIVITAI_DOMAIN_PREFER=com
CIVITAI_VERSIONS=
CIVITAI_QUEUE_PATH=
CIVITAI_DEFAULT_TARGET_DIR=loras
CIVITAI_DEFAULT_SUBDIR=
