COMFYUI_BASE=/workspace/ComfyUI
USE_HF_TRANSFER=1
FORCE_REDOWNLOAD=0
HF_MAX_WORKERS=4
DIRECT_MAX_WORKERS=2
INSTALL_NODES=1
NODES_PIP_INSTALL=1
NODES_FORCE_REINSTALL=0
NODES_USE_ZIP_FALLBACK=1
NODE_MANIFEST_PATH=/opt/template-config/manifests/custom_nodes.json
HF_MANIFEST_PATH=/opt/template-config/manifests/hf_models.json
ENABLED_NODE_GROUPS=core,workflow_common,workflow_svi,workflow_dasiwa,workflow_ops,default_extra_nodes
TEMPLATE_WORKFLOW_INCLUDE="Wan2.2_I2V_SVI_Kenpechi_Workflow_v3.5 12Sec (3).json,SVI pro.json,DaSiWa WAN 2.2 i2v FastFidelity C-SVI-34.json"
ENABLED_MODEL_GROUPS=common,wan22_i2v_base,wan22_i2v_fp8,wan22_text_fp8,wan22_text_bf16,wan22_visual,wan22_vae,svi,lightx2v_compat,lightx2v_kijai_260412,lightx2v_legacy,wan21_fallback,candidate,lightx2v_candidate,wan22_animate_candidate
DIRECT_USE_ARIA2=1
CIVITAI_FORCE_REDOWNLOAD=0
CIVITAI_ONLY_SAFETENSORS=1
CIVITAI_DOMAIN_PREFER=com
CIVITAI_VERSIONS=
CIVITAI_QUEUE_PATH=/opt/template-config/civitai_queues/runpod_default_loras.json
CIVITAI_DEFAULT_TARGET_DIR=loras
CIVITAI_DEFAULT_SUBDIR=
